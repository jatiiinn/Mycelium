# ---- Supabase (Dashboard -> Project Settings -> API) ----
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=eyJ...            # not used server-side, kept for future client features
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # SECRET — server only, never expose to the browser

# ---- Raindrop.io (app.raindrop.io -> Settings -> Integrations -> create app -> Test token) ----
RAINDROP_TOKEN=...

# ---- App access ----
MYCELIUM_PASSCODE=choose-a-passcode

# ---- Cron/sync protection (any long random string; also set the SAME value on the worker) ----
CRON_SECRET=generate-a-long-random-string
