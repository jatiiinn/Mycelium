# ---- Supabase (same project as the web app) ----
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- AI APIs ----
GROQ_API_KEY=gsk_...          # console.groq.com -> API Keys
GEMINI_API_KEY=AIza...        # aistudio.google.com -> Get API key

# ---- Optional ----
# Gemini model used for tagging/summaries (vision-capable). Change if Google
# retires this one.
GEMINI_MODEL=gemini-2.5-flash-lite
# If set, the worker calls your Vercel /api/sync every 10 minutes — a reliable
# replacement for Vercel Cron on the free (Hobby) plan, which only allows
# once-per-day crons. Use your deployed URL, e.g. https://your-app.vercel.app/api/sync
SYNC_URL=
CRON_SECRET=
# Extra flags appended to every yt-dlp call, e.g. --cookies /etc/secrets/cookies.txt
YTDLP_EXTRA_ARGS=
# Skip uploading extracted videos to Supabase Storage if larger than this (MB)
MAX_VIDEO_MB=60
